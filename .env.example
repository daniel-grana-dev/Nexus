# Copy this file as .env and fill in the real values
# NEVER push the .env file to GitHub

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic (optional)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram Bot
TELEGRAM_BOT_TOKEN=...

# PostgreSQL
POSTGRES_DB=nexus
POSTGRES_USER=nexus
POSTGRES_PASSWORD=change_this_to_something_secure

# Hetzner (for Terraform)
HCLOUD_TOKEN=...
